<div class="mx-auto max-w-lg space-y-6">
  <h1 class="text-xl font-bold text-foreground">Profil</h1>

  <div class="rounded-2xl border border-border bg-background-card p-6">
    <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-4" do |f| %>

      <div class="pb-4 border-b border-border">
        <h2 class="mb-3 text-sm font-semibold text-foreground">Kontoinformation</h2>
        <div class="space-y-3">
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">E-post</label>
            <div class="rounded-lg border border-border bg-background-elevated px-3 py-2 text-sm text-foreground-muted">
              <%= @user.email %>
            </div>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">Namn</label>
            <%= f.text_field :name,
                  class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                  placeholder: "Ditt namn" %>
          </div>
        </div>
      </div>

      <div class="pb-4 border-b border-border">
        <h2 class="mb-3 text-sm font-semibold text-foreground">Byt lösenord</h2>
        <div class="space-y-3">
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">Nytt lösenord</label>
            <%= f.password_field :password,
                  class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                  placeholder: "Lämna tomt för att behålla befintligt" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">Bekräfta lösenord</label>
            <%= f.password_field :password_confirmation,
                  class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" %>
          </div>
        </div>
      </div>

      <div>
        <h2 class="mb-3 text-sm font-semibold text-foreground">Jira-integration</h2>
        <div class="space-y-3">
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">Jira-URL</label>
            <%= f.url_field :jira_url,
                  class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                  placeholder: "https://your-org.atlassian.net" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">Jira-e-post</label>
            <%= f.email_field :jira_email,
                  class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                  placeholder: "din@epost.se" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-foreground-muted">API-token</label>
            <%= f.password_field :jira_api_token,
                  class: "w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent",
                  placeholder: "Din Jira API-token",
                  autocomplete: "off" %>
            <p class="mt-1 text-xs text-foreground-muted">
              Skapa en API-token på
              <a href="https://id.atlassian.com/manage/api-tokens" target="_blank" rel="noopener"
                 class="text-accent hover:underline">id.atlassian.com</a>
            </p>
          </div>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <%= f.submit "Spara ändringar",
              class: "rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
