<div class="space-y-6">
  <h1 class="text-xl font-bold text-foreground">Noteringar</h1>

  <%= turbo_frame_tag "notes-search" do %>
    <%= form_with url: notes_path, method: :get, data: { turbo_frame: "notes-list" }, class: "mb-4" do |f| %>
      <div class="flex gap-2">
        <%= f.search_field :q, value: @query,
              placeholder: "Sök noteringar…",
              class: "flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder-foreground-muted focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" %>
        <%= f.submit "Sök",
              class: "rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent-hover transition-colors cursor-pointer" %>
      </div>
    <% end %>
  <% end %>

  <%= turbo_frame_tag "notes-list" do %>
    <div class="space-y-3">
      <% if @notes.empty? %>
        <div class="rounded-xl border border-border bg-background-card p-8 text-center text-sm text-foreground-muted">
          <%= @query.present? ? "Inga noteringar matchar sökningen." : "Inga noteringar än." %>
        </div>
      <% else %>
        <% @notes.each do |note| %>
          <div class="card-glow rounded-xl border border-border bg-background-card p-4 hover:bg-background-card-hover transition-colors">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="mb-2 text-xs font-medium text-accent"><%= note.date %></div>
                <div class="prose-content text-sm text-foreground line-clamp-4">
                  <%= render_markdown(note.content) %>
                </div>
              </div>
              <%= link_to dashboard_path(date: note.date),
                    class: "shrink-0 rounded-lg p-1.5 text-foreground-muted hover:text-foreground transition-colors",
                    title: "Öppna i dashboard" do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
